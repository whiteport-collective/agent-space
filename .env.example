# Agent Space — Supabase credentials
# Copy this file to .env and fill in your values

# Your Supabase project URL (from Dashboard > Settings > API)
AGENT_SPACE_URL=https://YOUR-PROJECT-REF.supabase.co

# Your Supabase anon key (from Dashboard > Settings > API > anon public)
AGENT_SPACE_ANON_KEY=your-anon-key-here

# Optional: OpenRouter API key for semantic embeddings
# Get one at https://openrouter.ai/keys
# Without this, messaging and work orders still work — only semantic search is disabled
# OPENROUTER_API_KEY=your-openrouter-key-here

# Optional: Voyage AI key for visual similarity search
# Get one at https://www.voyageai.com/
# VOYAGE_API_KEY=your-voyage-key-here
